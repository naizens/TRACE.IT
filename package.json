{
  "name": "trace-it",
  "version": "0.12.0",
  "description": "TRACE.IT - iRacing telemetry analysis tool",
  "main": "out/main/index.js",
  "author": "Niclas Heide",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/hammerjs": "^2.0.46",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "hammerjs": "^2.0.8",
    "playwright-core": "^1.61.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.trace-it.app",
    "productName": "TRACE.IT",
    "asar": true,
    "electronLanguages": [
      "en"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "trackmaps",
        "to": "boundaries",
        "filter": ["**/*.json"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "naizens",
      "repo": "TRACE.IT"
    }
  }
}
